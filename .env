# ==========================================
# Auto Docker Updater - Configuration File
# 
# Instructions:
# Rename this file to '.env' and place it in the same folder as updater.sh.
# Adjust the paths below to match your specific server environment.
# ==========================================

# The master directory where all your separate container folders are located.
# The script will automatically scan all subdirectories here.
BASE_DIR=/home/$USER/docker

# Where to save the update logs
LOG_FILE=/home/$USER/docker/container-updater/log.log

# Directories to exclude from scanning (colon-separated folder names)
# Example: EXCLUDE_DIRS=container-updater:backups:testing
# EXCLUDE_DIRS=

# Override the path to the docker binary (optional)
# By default, the script will automatically detect the 'docker' command.
# DOCKER_BIN=/usr/local/bin/docker
